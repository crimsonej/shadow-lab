# Copy this file to .env and fill in your values

# Where Ollama is running (default: localhost:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Port for the agent to listen on
AGENT_PORT=8080

# Admin token used by the dashboard to manage keys/models
# Leave blank to auto-generate on first run (recommended)
ADMIN_TOKEN=

# Path to persist API keys
KEYS_FILE=/etc/ollama-agent/keys.json

# Max concurrent requests before queuing
MAX_CONCURRENT=4

# Enable GPU monitoring (requires nvidia-smi or rocm-smi)
GPU_MONITORING=true
